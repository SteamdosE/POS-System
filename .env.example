# ── Application ──────────────────────────────────────────────
ENV=development
SECRET_KEY=change-me-to-a-long-random-string
PORT=5000

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ACCESS_TOKEN_HOURS=24

# ── Database ─────────────────────────────────────────────────
# SQLite (default, for development):
DATABASE_URL=sqlite:///pos_system.db

# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/pos_system

# MySQL example:
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/pos_system

# ── Pagination ───────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=*

# ── Paystack ─────────────────────────────────────────────────
# Get your keys from https://dashboard.paystack.com/#/settings/developer
# Use sk_test_... / pk_test_... for test mode; sk_live_... / pk_live_... for production
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
